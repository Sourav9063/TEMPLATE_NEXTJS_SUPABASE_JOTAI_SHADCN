# Public app URL. Do not include a trailing slash.
NEXT_PUBLIC_APP_URL=http://localhost:8080

# Optional Google OAuth client ID. Leave empty to hide Google sign-in.
NEXT_PUBLIC_OAUTH_CLIENT_ID=

# Supabase Postgres connection string. Use the pooled connection string in production.
DATABASE_URL=postgresql://postgres:password@db.project.supabase.co:5432/postgres

# Supabase Storage. The service role key is server-only.
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=uploads

# Server-side session signing.
JWT_SECRET=replace-with-a-long-random-secret
JWT_MAX_AGE=7d
JWT_ALGORITHM=HS256

# Nodemailer SMTP.
SMTP_HOST=smtp.example.com
SMTP_PASS=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
